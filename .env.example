# Server
PORT=8080
GIN_MODE=debug

# Database (same as existing Firefly III)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=secret

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=14

# App
APP_VERSION=6.5.9
API_VERSION=2.1.0
DEFAULT_LOCALE=en_US
SITE_OWNER=admin@example.com
APP_ENV=production
APP_URL=http://localhost:8080
